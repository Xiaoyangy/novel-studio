{
  "skill": "story-review",
  "entrypoint": "SKILL.md",
  "always_read": [
    "SKILL.md",
    "CONTEXT.md",
    "context.json"
  ],
  "required_files": [],
  "conditional_files": [
    {
      "when": "需要该 skill 的方法论、模板、rubric、平台规则或阶段细节时读取。",
      "paths": [
        "references/anti-ai-writing.md",
        "references/banned-words.md",
        "references/character-relations.md",
        "references/dialogue-mastery.md",
        "references/human-feel-craft.md",
        "references/plot-core-methods.md",
        "references/quality-checklist.md",
        "references/quality-rubric.md",
        "references/refer-writing-techniques-digest.md",
        "references/rubrics/fanqie.md",
        "references/rubrics/qidian.md",
        "references/rubrics/zhihu.md"
      ]
    },
    {
      "when": "需要运行、检查或说明该 skill 的本地脚本时读取。",
      "paths": [
        "scripts/check-ai-patterns.js",
        "scripts/check-degeneration.js",
        "scripts/normalize-punctuation.js"
      ]
    }
  ],
  "state_files": [
    ".skill-context/story-review.md"
  ],
  "output_contract": [
    "按该 skill 的 SKILL.md 和 references 中声明的项目文件落盘，不把长正文只留在对话中。"
  ],
  "compaction_resume": [
    "压缩或恢复后先读本文件夹的 CONTEXT.md，再读执行目录中的 .skill-context/story-review.md（若存在）。",
    "确认已读文件清单、当前阶段、输入/输出路径、硬约束和下一步后再继续。",
    "不要把长正文、完整参考库或多本书设定塞进主会话；这些内容必须落盘并按需读取。"
  ]
}
